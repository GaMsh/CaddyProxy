i.esya.ru {
# Сохраняем ваши базовые заголовки
    header {
               Server ews
               -Via
           }

# Подключаем ваши стандарты безопасности и сжатия
    import security
    encode br zstd gzip

# 1. ВАЖНО: Корень сервера.
# Caddy должен знать, где физически искать папку public, чтобы проверять наличие картинок.
# Замените путь на реальный путь внутри контейнера/сервера Caddy.
    root * /app/public

# 2. Добавляем "вечный" кэш для статики.
# Срабатывает только если файл реально существует на диске.
    @static {
                file
            }
    header @static Cache-Control "public, max-age=31536000, immutable"

# 3. Главная магия маршрутизации (Static Fallback).
# Ищем файл. Если его нет — переписываем URL на /index.php, сохраняя оригинальный URI.
    try_files {path} /index.php{uri}

# 4. Обслуживаем найденные статические файлы напрямую, минуя PHP.
    file_server

# 5. Если файла не было (запрос переписан на /index.php), отправляем его в ваш backend.
    @php {
             path /index.php*
         }
    reverse_proxy @php h2c://new_esya_ru
}

